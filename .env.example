# Exemplo de configuração de variáveis de ambiente
# Copie este ficheiro para .env e preencha com suas credenciais

# Chave de API da Anthropic (obrigatória)
ANTHROPIC_API_KEY=sua-chave-anthropic-aqui

# Modelo Claude a usar (opcional - padrão: claude-sonnet-4-20250514)
# DEFAULT_MODEL=claude-sonnet-4-20250514

# Modelo spaCy (opcional - padrão: pt_core_news_lg)
# SPACY_MODEL=pt_core_news_lg
